# Relay (Ramos James Law) — environment variables

# --- Auth (optional) ---
# When not set to "true", Relay does not require sign-in (dashboard and APIs are open).
RELAY_REQUIRE_AUTH=false
RELAY_ADMIN_PASSWORD=
RELAY_SESSION_SECRET=

# --- Firebase Admin (optional for local demo) ---
# If omitted, Relay uses an in-memory store (data resets on restart).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Force mock DB even if Firebase credentials exist
USE_MOCK_DB=false

# --- Adobe Acrobat Sign (Phase 2) ---
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=
ADOBE_REFRESH_TOKEN=
ADOBE_BASE_URL=

# --- Twilio (Phase 2) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=

# --- Ops ---
SLACK_WEBHOOK_URL=
CRON_SECRET=
