# Sign Flow (Ramos James Law) — environment variables

# --- Auth (optional) ---
# Set true in production so /dashboard and /admin require Google sign-in.
SIGNFLOW_REQUIRE_AUTH=false
# Secret used to sign the Sign Flow session cookie after Firebase verifies Google sign-in.
SIGNFLOW_SESSION_SECRET=
# Comma-separated staff allowlist: full emails (user@firm.com) and/or domains (ramosjames.com or @ramosjames.com).
SIGNFLOW_ALLOWED_GOOGLE_EMAILS=
# Admins may permanently delete signing requests (comma-separated emails, must match Google sign-in).
SIGNFLOW_ADMIN_EMAILS=

# Firebase client (browser) — from Firebase Console → Project settings → Your apps → Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- DocuSeal ---
# Self-hosted (e.g. Railway): public app URL only — Sign Flow calls /api/templates automatically.
# Must be a LIVE hostname (Railway 404 "Application not found" = wrong or deleted deployment URL).
# Example: https://your-docuseal-service.up.railway.app
DOCUSEAL_API_URL=
DOCUSEAL_API_KEY=
DOCUSEAL_WEBHOOK_SECRET=
# Same host as DOCUSEAL_API_URL (web UI for "Open in DocuSeal" links). Not the /api path.
DOCUSEAL_ADMIN_BASE_URL=
SIGNFLOW_PLACEHOLDER_EMAIL_DOMAIN=client.invalid

# --- Firebase Admin (Firestore + verify Auth ID tokens) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Optional: non-default Firestore database ID (Console → Firestore → database picker).
FIRESTORE_DATABASE_ID=
# Set true for local/dev without Firestore, or if the API returns NOT_FOUND (no DB provisioned).
USE_MOCK_DB=false

# --- Quo / OpenPhone (SMS) — https://www.quo.com/docs/mdx/api-reference/authentication ---
QUO_API_KEY=
# E.164 of a number in YOUR Quo workspace (Settings → Phone numbers). Not a Twilio/other-provider number.
QUO_FROM_NUMBER=
# Or use the PN… id from GET https://api.openphone.com/v1/phone-numbers (preferred if E.164 lookup fails)
QUO_PHONE_NUMBER_ID=
# Optional: Quo user id (US…) to send as a specific workspace member
QUO_USER_ID=
# Local dev only: pretend SMS succeeded without calling Quo (omit in production)
QUO_SMS_MOCK=

# --- Email (preferred: Workspace domain-wide delegation, then user OAuth, then SendGrid) ---
# Dedicated service account (NOT the Firebase Admin SA) with domain-wide delegation to Gmail send:
# GMAIL_SERVICE_ACCOUNT_EMAIL = "client_email" from the JSON key (*@PROJECT.iam.gserviceaccount.com) — NOT the numeric Client ID.
GMAIL_SERVICE_ACCOUNT_EMAIL=
GMAIL_SERVICE_ACCOUNT_PRIVATE_KEY=
# Workspace mailbox this SA impersonates (From: address). Must exist in Google Workspace.
GMAIL_SEND_AS_EMAIL=
#
# Optional fallback — SendGrid:
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
# Optional fallback — Gmail as a single user via OAuth refresh token (not delegation):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_EMAIL_FROM=

# Optional: public origin of this app (no trailing slash) so HTML emails can load `/rj-logo.svg`.
# Example: https://sign.yourdomain.com — used when sending from the server.
SIGNFLOW_EMAIL_PUBLIC_ORIGIN=
# Optional: same origin for local admin → Messages preview (logo in iframe). Not required for sends.
NEXT_PUBLIC_SIGNFLOW_EMAIL_PUBLIC_ORIGIN=

# --- Dropbox ---
DROPBOX_ACCESS_TOKEN=

# --- Cron ---
CRON_SECRET=
